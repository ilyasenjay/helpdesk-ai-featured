    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.20",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
