generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Better Auth ────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(agent)
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  messages      Message[]
  assignedTickets Ticket[] @relation("TicketAssignee")

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  admin
  agent
}

enum TicketStatus {
  new
  processing
  open
  resolved
  closed
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}

enum MessageSender {
  CUSTOMER
  AGENT
  AI
}

// ── Domain Models ─────────────────────────────────────────────────────────────

model Ticket {
  id            Int             @id @default(autoincrement())
  subject       String
  body          String
  customerEmail String?
  senderName    String
  status        TicketStatus    @default(new)
  category      TicketCategory?
  aiSummary     String?
  resolvedByAi  Boolean         @default(false)
  assignedToId  String?
  assignedTo    User?           @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  messages      Message[]

  @@map("ticket")
}

model Message {
  id        String        @id @default(cuid())
  body      String
  sender    MessageSender
  ticketId  Int
  ticket    Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@map("message")
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_base")
}
