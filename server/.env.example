# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://helpdesk:helpdesk@localhost:5432/helpdesk?schema=public"

# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_ME_with_a_32_char_random_secret"

BETTER_AUTH_URL="http://localhost:3000"

# The URL the browser-side client is served from (used for CORS and trusted origins)
CLIENT_URL="http://localhost:5173"

ADMIN_EMAIL="admin@example.com"
# Choose a strong password before running the seed script
ADMIN_PASSWORD="REPLACE_ME"
