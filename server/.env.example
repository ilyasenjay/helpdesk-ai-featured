# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://helpdesk:helpdesk@localhost:5432/helpdesk?schema=public"

# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_ME_with_a_32_char_random_secret"

BETTER_AUTH_URL="http://localhost:3000"

# The URL the browser-side client is served from (used for CORS and trusted origins)
CLIENT_URL="http://localhost:5173"

ADMIN_EMAIL="admin@example.com"
# Choose a strong password before running the seed script
ADMIN_PASSWORD="REPLACE_ME"

# Mailgun inbound email webhook signing key
# Find it in Mailgun dashboard → Sending → Webhooks → HTTP webhook signing key
# When set, the /api/webhooks/email endpoint verifies each request's HMAC-SHA256 signature.
# When absent (e.g. local dev), signature verification is skipped.
# MAILGUN_WEBHOOK_SIGNING_KEY=your-mailgun-http-webhook-signing-key

# Groq API key (console.groq.com → API Keys) — powers the "Polish" reply button.
# Free tier, no credit card required (rate-limited: ~30 req/min, ~1000 req/day as of writing).
# When absent, the polish endpoint returns a 503 instead of crashing the server.
# GROQ_API_KEY=gsk_...

# Groq model used for polishing. Verify the current ID at console.groq.com/docs/models
# before relying on the default below.
# GROQ_MODEL=llama-3.3-70b-versatile

# Gmail inbound email polling — an alternative to the Mailgun/SendGrid webhook above for when you
# don't own a domain (those services require pointing a domain's MX records at them). Instead, the
# server polls a Gmail inbox every minute via the Gmail API and creates a ticket for each unread
# message carrying the "Helpdesk" label (see lib/gmail/poll.ts), then marks it read.
#
# IMPORTANT: this only looks at mail labeled "Helpdesk" — never the whole inbox. A personal Gmail
# account also receives ordinary mail (newsletters, bank alerts, etc.), so scanning all unread mail
# would turn all of that into tickets too. Use Gmail's "+" alias trick to scope what counts as a
# support request, without needing a second mailbox:
#   1. In Gmail settings → Filters and Blocked Addresses → Create a new filter:
#      To: your-address+support@gmail.com  →  Apply the label: "Helpdesk" (create it).
#   2. Give out your-address+support@gmail.com as the support contact address. Mail sent there
#      still lands in your normal inbox (plus-addressing is just routing) but now carries the
#      label, so only it gets turned into tickets.
#
# Setup:
#   1. In https://console.cloud.google.com, create a project (or reuse one) and enable the
#      "Gmail API" (APIs & Services → Library).
#   2. APIs & Services → OAuth consent screen: User type "External", add the Gmail address below
#      as a test user, and add scope https://www.googleapis.com/auth/gmail.modify.
#      Then set Publishing status to "In production" (Testing-mode tokens expire after 7 days;
#      you don't need Google's verification for personal use — you'll see an "unverified app"
#      warning during consent, which is expected, just click through it).
#   3. APIs & Services → Credentials → Create Credentials → OAuth client ID → type "Desktop app".
#      Copy the Client ID and Client Secret below.
#   4. Run `bun run gmail:auth`, open the printed URL, sign in with the Gmail account that should
#      receive tickets, and grant access. The script prints GMAIL_REFRESH_TOKEN — paste it below.
#   5. Set up the Gmail filter + label described above BEFORE starting the server with these vars
#      set, so the poller has nothing to match until you intentionally send it a support email.
# GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=your-client-secret
# GMAIL_REFRESH_TOKEN=paste-the-value-printed-by-`bun run gmail:auth`

# Outbound replies — sends agent/AI ticket replies back to the customer as an actual email (via
# Gmail's SMTP relay, authenticated with an app password rather than OAuth — simpler for send-only
# access). Only applies to tickets that came in through the Gmail poller above (it needs a Gmail
# thread to reply into); replies on other tickets are still saved in the ticket, just not emailed.
# Requires 2-Step Verification enabled on the account. Generate one at
# https://myaccount.google.com/apppasswords (name it anything, e.g. "helpdesk").
# GMAIL_ADDRESS=your-address@gmail.com
# GMAIL_SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
